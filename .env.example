# --- Credenciales Gmail (SMTP) ---
# Tu cuenta de Gmail desde la que se envía el correo.
GMAIL_USER=tu-correo@gmail.com

# Contraseña de aplicación de Google (NO tu contraseña normal).
# Crea una en: https://myaccount.google.com/apppasswords
# Requiere tener la verificación en dos pasos activada.
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# --- Destinatario ---
# Correo donde quieres recibir el Evangelio diario.
TO_EMAIL=destinatario@gmail.com

# --- Opcional ---
# Solo si en el futuro usas una API que requiera clave.
API_KEY=

# Modo prueba: si es "1" no envía el correo, solo imprime el contenido.
DRY_RUN=0
